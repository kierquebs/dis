# =============================================================================
# SendGrid SMTP
# =============================================================================
# Protocol must be "smtp" for SendGrid.
MAIL_DRIVER=smtp
MAIL_HOST=smtp.sendgrid.net
MAIL_PORT=587

# SendGrid requires the literal string "apikey" as the SMTP username.
MAIL_USERNAME=apikey

# Paste your SendGrid API key here.
# To generate one:
#   1. Log in to https://app.sendgrid.com
#   2. Go to Settings → API Keys → Create API Key
#   3. Choose "Restricted Access", enable Mail Send → Full Access
#   4. Copy the key (shown only once) — it starts with "SG."
SENDGRID_API_KEY=SG.xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# MAIL_PASSWORD overrides SENDGRID_API_KEY when both are set.
# Leave blank to use SENDGRID_API_KEY.
# MAIL_PASSWORD=

# =============================================================================
# Sender Identity
# =============================================================================
# The "From" address must be verified in SendGrid:
#   Settings → Sender Authentication → Verify a Single Sender  (quickest)
#   — or —
#   Settings → Sender Authentication → Authenticate Your Domain  (recommended for production)
MAIL_FROM=gift@notifications.pluxee.ph
MAIL_FROM_NAME="Pluxee Admin"
