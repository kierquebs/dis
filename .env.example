# =============================================================================
# Gmail SMTP
# =============================================================================
MAIL_DRIVER=smtp
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_ENCRYPTION=tls

# Your full Gmail address.
MAIL_USERNAME=you@gmail.com

# Gmail App Password (NOT your regular Gmail login password).
# Google blocks plain passwords for SMTP — you must use an App Password.
#
# How to generate one:
#   1. Make sure 2-Step Verification is ON for your Google account:
#      https://myaccount.google.com/security
#   2. Go to App Passwords:
#      https://myaccount.google.com/apppasswords
#   3. Select app: "Mail", select device: "Other" → type "DIS" → Generate
#   4. Copy the 16-character password shown (no spaces).
MAIL_PASSWORD=xxxxxxxxxxxxxxxx

# =============================================================================
# Sender Identity
# =============================================================================
# Gmail will override the From address with your authenticated Gmail address
# unless you have "Send mail as" configured in Gmail settings.
MAIL_FROM=you@gmail.com
MAIL_FROM_NAME="Pluxee Admin"
